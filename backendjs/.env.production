# Production Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8888
NODE_ENV=production
TZ=Asia/Ho_Chi_Minh

# Database Configuration (Supabase PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT_ID].supabase.co:5432/postgres

# Supabase Configuration
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_ANON_KEY=[ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# OpenRouter AI Configuration
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=[YOUR_OPENROUTER_API_KEY]
OPENROUTER_MODEL=deepseek/deepseek-chat

# CORS Configuration
CORS_ORIGIN=https://bazi-frontend.render.com,http://localhost:3005

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
RATE_LIMIT_AUTH_MAX=50
RATE_LIMIT_AI_MAX=15

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Session Configuration
SESSION_EXPIRY_DAYS=7
SESSION_SECRET=[GENERATE_RANDOM_SECRET]

# Feature Flags
ENABLE_AI_CONSULTANT=true
ENABLE_MATCHING=true
ENABLE_ARTICLES=true
ENABLE_ADMIN_PANEL=true

# Monitoring
SENTRY_DSN=[OPTIONAL_SENTRY_DSN]
